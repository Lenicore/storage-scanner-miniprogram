.profile-page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background: #f5f5f7;
}

.profile-hero {
  margin-bottom: 24rpx;
  padding: 8rpx 8rpx 16rpx;
}

.profile-title {
  display: block;
  color: #111111;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
}

.profile-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.6;
}

.profile-card {
  padding: 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

.profile-avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 28rpx;
}

.avatar-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 180rpx;
  height: 180rpx;
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 999rpx;
  background: transparent;
  line-height: 1;
}

.avatar-picker::after,
.profile-save-btn::after {
  border: 0;
}

.profile-avatar-image,
.profile-avatar-placeholder {
  width: 180rpx;
  height: 180rpx;
  border-radius: 999rpx;
}

.profile-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f3f4f6;
  border: 1rpx solid #e5e7eb;
}

.profile-avatar-placeholder-text {
  color: #6b7280;
  font-size: 24rpx;
  font-weight: 600;
}

.profile-avatar-tip {
  display: block;
  margin-top: 16rpx;
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.5;
}

.profile-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.profile-label {
  display: block;
  color: #8e8e93;
  font-size: 24rpx;
}

.profile-value {
  display: block;
  margin-top: 10rpx;
  color: #111111;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.6;
}

.profile-input {
  width: 100%;
  height: 84rpx;
  margin-top: 12rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  box-sizing: border-box;
  color: #111111;
  font-size: 30rpx;
}

.profile-save-btn {
  width: 100%;
  height: 88rpx;
  margin: 28rpx 0 0;
  padding: 0 28rpx;
  border: 0;
  border-radius: 20rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 88rpx;
  box-sizing: border-box;
}

.profile-save-btn[disabled] {
  background: #d1d5db;
  color: #9ca3af;
}

.profile-empty {
  color: #8e8e93;
  font-size: 26rpx;
  line-height: 1.6;
}
