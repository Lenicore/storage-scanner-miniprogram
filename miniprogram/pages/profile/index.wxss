.profile-page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background: #f5f5f7;
}

.profile-hero {
  margin-bottom: 24rpx;
  padding: 8rpx 8rpx 16rpx;
}

.profile-title {
  display: block;
  color: #111111;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
}

.profile-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.6;
}

.profile-card {
  padding: 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

.profile-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.profile-label {
  display: block;
  color: #8e8e93;
  font-size: 24rpx;
}

.profile-value {
  display: block;
  margin-top: 10rpx;
  color: #111111;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.6;
}

.profile-openid {
  font-size: 24rpx;
  font-weight: 400;
  word-break: break-all;
}

.profile-empty {
  color: #8e8e93;
  font-size: 26rpx;
  line-height: 1.6;
}
