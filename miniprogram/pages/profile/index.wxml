<view class="profile-page">
  <view class="profile-hero">
    <text class="profile-title">我的信息</text>
    <text class="profile-subtitle">完善头像和昵称后，管理员识别员工会更清晰。</text>
  </view>

  <view class="profile-card" wx:if="{{userInfo}}">
    <view class="profile-avatar-section">
      <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="handleChooseAvatar">
        <image wx:if="{{formAvatarUrl}}" class="profile-avatar-image" src="{{formAvatarUrl}}" mode="aspectFill" />
        <view wx:else class="profile-avatar-placeholder">
          <text class="profile-avatar-placeholder-text">选择头像</text>
        </view>
      </button>
      <text class="profile-avatar-tip">点击头像选择新的微信头像</text>
    </view>

    <view class="profile-item">
      <text class="profile-label">昵称</text>
      <input
        class="profile-input"
        type="nickname"
        placeholder="请输入昵称"
        value="{{formName}}"
        bindinput="handleNameInput"
      />
    </view>

    <view class="profile-item">
      <text class="profile-label">角色</text>
      <text class="profile-value">{{userInfo.roleText}}</text>
    </view>

    <view class="profile-item">
      <text class="profile-label">状态</text>
      <text class="profile-value">{{userInfo.statusText}}</text>
    </view>

    <button class="profile-save-btn" disabled="{{isSaving}}" bindtap="handleSaveProfile">
      {{isSaving ? '保存中' : '保存资料'}}
    </button>

    <button wx:if="{{userInfo.canManageUsers}}" class="profile-manage-btn" bindtap="handleOpenUserAdmin">
      用户管理
    </button>
  </view>

  <view class="profile-card" wx:else>
    <text class="profile-empty">正在初始化用户信息...</text>
  </view>
</view>
