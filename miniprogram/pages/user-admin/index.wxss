.user-admin-page {
  min-height: 100vh;
  padding: 48rpx 24rpx 40rpx;
  background: #f5f5f7;
  box-sizing: border-box;
}

.user-admin-hero {
  margin-bottom: 20rpx;
  padding: 8rpx 8rpx 12rpx;
}

.user-admin-title {
  display: block;
  color: #111111;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
}

.user-admin-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.6;
}

.user-admin-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.user-admin-card {
  padding: 24rpx 20rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
}

.user-admin-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.user-admin-main {
  flex: 1;
  min-width: 0;
}

.user-admin-name {
  display: block;
  color: #111111;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.user-admin-openid {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.5;
  word-break: break-all;
}

.user-admin-role-btn {
  flex-shrink: 0;
  min-width: 148rpx;
  height: 64rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #1677ff;
  color: #ffffff;
  border: 0;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 64rpx;
  box-sizing: border-box;
}

.user-admin-role-btn::after {
  border: 0;
}

.user-admin-role-btn[disabled] {
  background: #d1d5db;
  color: #9ca3af;
}

.user-admin-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.user-admin-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f1ff;
  color: #1677ff;
  font-size: 22rpx;
  line-height: 1.4;
}

.user-admin-tag-muted {
  background: #f3f4f6;
  color: #6b7280;
}

.user-admin-empty {
  color: #8e8e93;
  font-size: 26rpx;
  line-height: 1.6;
}
