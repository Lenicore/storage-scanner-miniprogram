.page {
  min-height: 100vh;
  width: 100%;
  padding: 56rpx 32rpx 40rpx;
  background: #f5f5f7;
  align-items: stretch;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 28rpx;
  padding: 8rpx 4rpx 8rpx;
}

.page-title {
  display: block;
  color: #111111;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
}

.page-subtitle {
  display: block;
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.6;
}

.card {
  width: 100%;
  margin-bottom: 20rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
  box-sizing: border-box;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-header-compact {
  margin-bottom: 18rpx;
}

.section-title {
  display: block;
  color: #111111;
  font-size: 30rpx;
  font-weight: 600;
}

.section-desc {
  display: block;
  margin-top: 8rpx;
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.5;
}

.category-card {
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}

.category-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.category-summary {
  flex: 1;
  min-width: 0;
}

.category-summary-label {
  display: block;
  color: #8e8e93;
  font-size: 22rpx;
}

.category-summary-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.category-summary-name {
  max-width: 100%;
  color: #111111;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
}

.category-summary-tag {
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f1ff;
  color: #1677ff;
  font-size: 20rpx;
}

.category-summary-empty {
  display: block;
  margin-top: 8rpx;
  color: #8e8e93;
  font-size: 26rpx;
}

.category-create-btn {
  flex-shrink: 0;
  height: 72rpx;
  padding: 0 28rpx;
  border: 0;
  border-radius: 18rpx;
  background: #eef2f7;
  color: #111111;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 72rpx;
}

.category-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.category-scroll-inner {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 8rpx;
}

.category-hint-text {
  display: block;
  margin-top: 16rpx;
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.6;
}

.category-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
}

.category-chip-active {
  background: #1677ff;
}

.category-chip-text {
  color: #111111;
  font-size: 24rpx;
  line-height: 1.2;
}

.category-chip-tag {
  color: #6b7280;
  font-size: 20rpx;
  line-height: 1.2;
}

.scan-card {
  padding-top: 34rpx;
  padding-bottom: 34rpx;
  text-align: center;
}

.scan-card-label {
  display: block;
  color: #8e8e93;
  font-size: 22rpx;
}

.scan-card-title {
  display: block;
  margin-top: 8rpx;
  color: #111111;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.scan-card-desc {
  display: block;
  margin-top: 10rpx;
  color: #8e8e93;
  font-size: 24rpx;
}

.scan-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  margin-top: 24rpx;
  border: 0;
  border-radius: 24rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
}

.category-chip-active .category-chip-text {
  color: #ffffff;
}

.category-chip-active .category-chip-tag {
  color: rgba(255, 255, 255, 0.85);
}

.result-card {
  padding-top: 26rpx;
}

.result-grid {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.result-item {
  padding: 20rpx 22rpx;
  background: #f8fafc;
  border-radius: 20rpx;
}

.result-label {
  display: block;
  color: #8e8e93;
  font-size: 24rpx;
}

.result-value {
  display: block;
  margin-top: 10rpx;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.records-card {
  padding-top: 26rpx;
}

.record-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.record-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.record-type {
  color: #6b7280;
  font-size: 24rpx;
  font-weight: 500;
}

.record-time {
  flex-shrink: 0;
  color: #8e8e93;
  font-size: 22rpx;
}

.record-value {
  display: block;
  margin-top: 10rpx;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.record-category {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f1ff;
  color: #1677ff;
  font-size: 22rpx;
}

.empty-state {
  padding: 16rpx 0 4rpx;
}

.empty-text {
  color: #8e8e93;
  font-size: 26rpx;
  line-height: 1.6;
}
