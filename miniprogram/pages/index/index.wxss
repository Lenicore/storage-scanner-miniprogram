.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background: #f5f5f7;
}

.hero {
  margin-bottom: 24rpx;
  padding: 8rpx 8rpx 16rpx;
}

.page-title {
  display: block;
  color: #111111;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
}

.page-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.6;
}

.card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  color: #111111;
  font-size: 32rpx;
  font-weight: 600;
}

.section-desc {
  display: block;
  margin-top: 8rpx;
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.5;
}

.scan-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  border: 0;
  border-radius: 24rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
}

.result-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-item {
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 20rpx;
}

.result-label {
  display: block;
  color: #8e8e93;
  font-size: 24rpx;
}

.result-value {
  display: block;
  margin-top: 10rpx;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.record-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.record-type {
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 600;
}

.record-time {
  flex-shrink: 0;
  color: #8e8e93;
  font-size: 24rpx;
}

.record-value {
  display: block;
  margin-top: 12rpx;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.empty-state {
  padding: 24rpx 0 8rpx;
}

.empty-text {
  color: #8e8e93;
  font-size: 26rpx;
  line-height: 1.6;
}
