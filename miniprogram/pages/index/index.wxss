.page {
  min-height: 100vh;
  width: 100%;
  padding: 56rpx 32rpx 40rpx;
  background: #f5f5f7;
  align-items: stretch;
  box-sizing: border-box;
}

.hero {
  margin-bottom: 28rpx;
  padding: 8rpx 4rpx 8rpx;
}

.page-title {
  display: block;
  color: #111111;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
}

.page-subtitle {
  display: block;
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.6;
}

.card {
  width: 100%;
  margin-bottom: 20rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
  box-sizing: border-box;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-header-compact {
  margin-bottom: 18rpx;
}

.section-title {
  display: block;
  color: #111111;
  font-size: 30rpx;
  font-weight: 600;
}

.section-desc {
  display: block;
  margin-top: 8rpx;
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.5;
}

.category-panel {
  padding-top: 26rpx;
  padding-bottom: 26rpx;
}

.category-current-row {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 12rpx 16rpx;
}

.category-current-label {
  flex-shrink: 0;
  color: #6b7280;
  font-size: 26rpx;
  font-weight: 600;
}

.category-current-value {
  flex: 1;
  min-width: 0;
  color: #111111;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-all;
}

.category-current-placeholder {
  color: #9ca3af;
  font-size: 30rpx;
  font-weight: 600;
}

.category-alert {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #fff4e6;
  border: 1rpx solid #ffd59c;
}

.category-alert-text {
  color: #b45309;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
}

.category-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 22rpx;
}

.btn-block {
  width: 100%;
  height: 88rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 88rpx;
  box-sizing: border-box;
}

.btn-secondary {
  border: 2rpx solid #1677ff;
  background: #ffffff;
  color: #1677ff;
}

.btn-primary-soft {
  border: 0;
  background: #1677ff;
  color: #ffffff;
}

.category-footnote {
  display: block;
  margin-top: 18rpx;
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.55;
}

.scan-card {
  padding-top: 34rpx;
  padding-bottom: 34rpx;
  text-align: center;
}

.scan-card-label {
  display: block;
  color: #8e8e93;
  font-size: 22rpx;
}

.scan-card-title {
  display: block;
  margin-top: 8rpx;
  color: #111111;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.scan-card-desc {
  display: block;
  margin-top: 10rpx;
  color: #8e8e93;
  font-size: 24rpx;
}

.scan-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  margin-top: 24rpx;
  border: 0;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
}

.scan-btn-active {
  background: #1677ff;
  color: #ffffff;
}

.scan-btn-muted {
  background: #d1d5db;
  color: #f9fafb;
}

.scan-btn[disabled] {
  background: #d1d5db;
  color: #9ca3af;
}

.result-card {
  padding-top: 26rpx;
}

.result-grid {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.result-notice {
  margin-bottom: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #fff4e6;
  border: 1rpx solid #ffd59c;
}

.result-notice-text {
  color: #b45309;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.5;
}

.result-qr-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 18rpx;
}

.result-qr-image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 20rpx;
  background: #f8fafc;
}

.result-item {
  padding: 20rpx 22rpx;
  background: #f8fafc;
  border-radius: 20rpx;
}

.result-label {
  display: block;
  color: #8e8e93;
  font-size: 24rpx;
}

.result-value {
  display: block;
  margin-top: 10rpx;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.records-card {
  padding-top: 26rpx;
}

.record-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.record-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-qr-image,
.record-qr-placeholder {
  width: 132rpx;
  height: 132rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
  background: #f8fafc;
}

.record-qr-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-qr-placeholder-text {
  color: #9ca3af;
  font-size: 22rpx;
}

.record-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.record-type {
  color: #6b7280;
  font-size: 24rpx;
  font-weight: 500;
}

.record-time {
  flex-shrink: 0;
  color: #8e8e93;
  font-size: 22rpx;
}

.record-value {
  display: block;
  margin-top: 10rpx;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.record-category {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f1ff;
  color: #1677ff;
  font-size: 22rpx;
}

.empty-state {
  padding: 16rpx 0 4rpx;
}

.empty-text {
  color: #8e8e93;
  font-size: 26rpx;
  line-height: 1.6;
}

.picker-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.picker-sheet {
  width: 100%;
  max-height: 65vh;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

.picker-sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-sheet-title {
  color: #111111;
  font-size: 32rpx;
  font-weight: 700;
}

.picker-sheet-close {
  color: #1677ff;
  font-size: 28rpx;
  font-weight: 600;
}

.picker-sheet-body {
  max-height: 52vh;
  padding: 8rpx 0 24rpx;
  box-sizing: border-box;
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 26rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f7;
}

.picker-row-active {
  background: #f0f7ff;
}

.picker-row-name {
  flex: 1;
  min-width: 0;
  color: #111111;
  font-size: 30rpx;
  font-weight: 500;
}

.picker-row-tag {
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f1ff;
  color: #1677ff;
  font-size: 22rpx;
}
