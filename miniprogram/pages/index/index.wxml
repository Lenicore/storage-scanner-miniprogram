<view class="container page">
  <view class="hero">
    <text class="page-title">扫码系统</text>
    <text class="page-subtitle">先选好分类，再连续扫码；记录按分类整理。</text>
  </view>

  <view class="card category-panel">
    <view class="category-current-row">
      <text class="category-current-label">当前分类</text>
      <text wx:if="{{selectedCategory}}" class="category-current-value">{{selectedCategory.name}}</text>
      <text wx:else class="category-current-placeholder">未选择</text>
    </view>

    <view wx:if="{{!selectedCategory}}" class="category-alert">
      <text class="category-alert-text">请先选择或新建分类</text>
    </view>

    <view class="category-actions">
      <button class="btn-primary-soft btn-block" bindtap="handleOpenCategoryPicker">选择分类</button>
      <button class="btn-secondary btn-block" bindtap="handleCreateCategory">新建分类</button>
    </view>

    <text wx:if="{{!categories.length}}" class="category-footnote">还没有分类，请先新建。</text>
    <text wx:elif="{{selectedCategory}}" class="category-footnote">可随时点击「选择分类」切换。</text>
  </view>

  <view class="card scan-card">
    <text class="scan-card-label">扫码</text>
    <text class="scan-card-title">开始扫码</text>
    <text class="scan-card-desc">仅保存到当前分类</text>

    <button
      class="scan-btn {{selectedCategory ? 'scan-btn-active' : 'scan-btn-muted'}}"
      disabled="{{!selectedCategory}}"
      bindtap="handleScan"
    >
      开始扫码
    </button>
  </view>

  <view class="card result-card" wx:if="{{scanResult}}">
    <view class="section-header section-header-compact">
      <text class="section-title">扫码结果</text>
    </view>

    <view wx:if="{{scanNotice}}" class="result-notice">
      <text class="result-notice-text">{{scanNotice}}</text>
    </view>

    <view wx:if="{{scanResult.qrFileId}}" class="result-qr-wrap">
      <image class="result-qr-image" src="{{scanResult.qrFileId}}" mode="aspectFit" />
    </view>

    <view class="result-grid">
      <view class="result-item">
        <text class="result-label">code_value</text>
        <text class="result-value">{{scanResult.codeValue}}</text>
      </view>

      <view class="result-item">
        <text class="result-label">code_type</text>
        <text class="result-value">{{scanResult.codeTypeText}}</text>
      </view>

      <view class="result-item">
        <text class="result-label">分类</text>
        <text class="result-value">{{scanResult.categoryName}}</text>
      </view>

      <view class="result-item">
        <text class="result-label">时间</text>
        <text class="result-value">{{scanResult.scanTime}}</text>
      </view>

      <view class="result-item">
        <text class="result-label">状态</text>
        <text class="result-value">{{scanResult.statusText}}</text>
      </view>
    </view>
  </view>

  <view class="card records-card">
    <view class="section-header section-header-compact">
      <text class="section-title">最近扫码记录</text>
    </view>

    <view wx:if="{{recentRecords.length}}">
      <view class="record-item" wx:for="{{recentRecords}}" wx:key="id">
        <view class="record-row">
          <image wx:if="{{item.qrFileId}}" class="record-qr-image" src="{{item.qrFileId}}" mode="aspectFit" />
          <view wx:else class="record-qr-placeholder">
            <text class="record-qr-placeholder-text">待生成</text>
          </view>
          <view class="record-main">
            <view class="record-meta">
              <view class="record-left">
                <text wx:if="{{item.categoryName}}" class="record-category">{{item.categoryName}}</text>
                <text class="record-type">{{item.codeTypeText}}</text>
              </view>
              <text class="record-time">{{item.scanTime}}</text>
            </view>
            <text class="record-value">{{item.codeValue}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-text">暂无扫码记录，选好分类后试一次扫码吧。</text>
    </view>
  </view>

  <view wx:if="{{categoryPickerVisible}}" class="picker-mask" bindtap="handleCloseCategoryPicker">
    <view class="picker-sheet" catchtap="noop">
      <view class="picker-sheet-head">
        <text class="picker-sheet-title">选择分类</text>
        <text class="picker-sheet-close" bindtap="handleCloseCategoryPicker">关闭</text>
      </view>
      <scroll-view class="picker-sheet-body" scroll-y="true">
        <view
          wx:for="{{categories}}"
          wx:key="id"
          class="picker-row {{selectedCategory && selectedCategory.id === item.id ? 'picker-row-active' : ''}}"
          data-id="{{item.id}}"
          bindtap="handlePickCategoryRow"
        >
          <text class="picker-row-name">{{item.name}}</text>
          <text wx:if="{{item.isLocked}}" class="picker-row-tag">公共</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
