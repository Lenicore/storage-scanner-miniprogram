<view class="container page">
  <view class="hero">
    <text class="page-title">扫码系统</text>
    <text class="page-subtitle">保持简单，先选分类，再开始扫码。</text>
  </view>

  <view class="card category-card">
    <view class="category-bar">
      <view class="category-summary">
        <text class="category-summary-label">当前分类</text>

        <view wx:if="{{selectedCategory}}" class="category-summary-main">
          <text class="category-summary-name">{{selectedCategory.name}}</text>
          <text wx:if="{{selectedCategory.isLocked}}" class="category-summary-tag">公共</text>
        </view>

        <text wx:else class="category-summary-empty">未选择分类</text>
      </view>

      <button class="category-create-btn" bindtap="handleCreateCategory">新建</button>
    </view>

    <scroll-view wx:if="{{categories.length}}" class="category-scroll" scroll-x="true" enable-flex="true" show-scrollbar="false">
      <view class="category-scroll-inner">
        <view
          wx:for="{{categories}}"
          wx:key="id"
          class="category-chip {{selectedCategory && selectedCategory.id === item.id ? 'category-chip-active' : ''}}"
          data-id="{{item.id}}"
          bindtap="handleSelectCategory"
        >
          <text class="category-chip-text">{{item.name}}</text>
          <text wx:if="{{item.isLocked}}" class="category-chip-tag">公共</text>
        </view>
      </view>
    </scroll-view>

    <text wx:else class="category-hint-text">还没有分类，先新建一个再扫码。</text>
  </view>

  <view class="card scan-card">
    <text class="scan-card-label">主操作</text>
    <text class="scan-card-title">开始扫码</text>
    <text class="scan-card-desc">保存前需要先选择分类</text>

    <button class="scan-btn" bindtap="handleScan">开始扫码</button>
  </view>

  <view class="card result-card" wx:if="{{scanResult}}">
    <view class="section-header section-header-compact">
      <text class="section-title">扫码结果</text>
    </view>

    <view class="result-grid">
      <view class="result-item">
        <text class="result-label">code_value</text>
        <text class="result-value">{{scanResult.codeValue}}</text>
      </view>

      <view class="result-item">
        <text class="result-label">code_type</text>
        <text class="result-value">{{scanResult.codeType}}</text>
      </view>

      <view class="result-item">
        <text class="result-label">分类</text>
        <text class="result-value">{{scanResult.categoryName}}</text>
      </view>

      <view class="result-item">
        <text class="result-label">时间</text>
        <text class="result-value">{{scanResult.scanTime}}</text>
      </view>
    </view>
  </view>

  <view class="card records-card">
    <view class="section-header section-header-compact">
      <text class="section-title">最近扫码记录</text>
    </view>

    <view wx:if="{{recentRecords.length}}">
      <view class="record-item" wx:for="{{recentRecords}}" wx:key="id">
        <view class="record-meta">
          <view class="record-left">
            <text wx:if="{{item.categoryName}}" class="record-category">{{item.categoryName}}</text>
            <text class="record-type">{{item.codeType}}</text>
          </view>
          <text class="record-time">{{item.scanTime}}</text>
        </view>
        <text class="record-value">{{item.codeValue}}</text>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-text">暂无扫码记录，先试一次扫码吧。</text>
    </view>
  </view>
</view>