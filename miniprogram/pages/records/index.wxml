<view class="records-page">
  <view class="records-hero">
    <text class="records-title">扫码记录</text>
    <text class="records-subtitle">按分类分组查看，组内按时间从新到旧。</text>
  </view>

  <view wx:if="{{roleModeText}}" class="admin-banner">
    <text class="admin-banner-text">{{roleModeText}}</text>
  </view>

  <view wx:if="{{currentCategoryViewId}}" class="current-category-card">
    <view class="current-category-main">
      <text class="current-category-label">当前分类</text>
      <text class="current-category-name">{{currentCategoryViewName}}</text>
    </view>
    <text class="current-category-back" bindtap="handleExitCategoryView">返回全部</text>
  </view>

  <view class="search-card">
    <view class="filter-date-box">
      <input
        class="filter-date-input"
        type="number"
        maxlength="8"
        placeholder="输入日期，如 20260402"
        value="{{dateFilterInput}}"
        bindinput="handleDateFilterInput"
      />
      <text wx:if="{{dateFilterInput}}" class="filter-date-clear" bindtap="handleClearDateFilter">清空</text>
    </view>
    <text wx:if="{{dateFilterTip}}" class="filter-tip">{{dateFilterTip}}</text>

    <view class="filter-select-row">
      <view class="filter-select-card" bindtap="openStatusFilterSheet">
        <text class="filter-select-label">状态</text>
        <view class="filter-select-value-wrap">
          <text class="filter-select-value">{{statusFilterText}}</text>
          <text class="filter-select-arrow">⌄</text>
        </view>
      </view>

      <view class="filter-select-card filter-select-card-wide" bindtap="openCategoryFilterSheet">
        <text class="filter-select-label">分类</text>
        <view class="filter-select-value-wrap">
          <text class="filter-select-value">{{categoryFilterText}}</text>
          <text class="filter-select-arrow">⌄</text>
        </view>
      </view>
    </view>

    <view wx:if="{{canViewAllRecords}}" class="search-box search-box-secondary">
      <input
        class="search-input"
        placeholder="筛选 user_id / user_name"
        value="{{userKeyword}}"
        bindinput="handleUserKeywordInput"
      />
      <text wx:if="{{userKeyword}}" class="search-clear" bindtap="handleClearUserKeyword">清空</text>
    </view>

  </view>

  <view class="batch-toolbar">
    <button
      class="batch-toggle-btn {{isBatchMode ? 'batch-toggle-btn-active' : ''}}"
      bindtap="handleToggleBatchMode"
    >
      {{isBatchMode ? '退出批量' : '批量管理'}}
    </button>
    <button
      wx:if="{{isBatchMode}}"
      class="batch-clear-btn"
      disabled="{{!selectedCount || isBatchProcessing}}"
      bindtap="handleClearSelection"
    >
      清空选择
    </button>
    <button
      wx:if="{{currentUserRole === 'admin'}}"
      class="batch-clear-btn"
      disabled="{{isExporting}}"
      bindtap="handleExportQrCodes"
    >
      {{isExporting ? '导出中' : '导出二维码'}}
    </button>
  </view>

  <view wx:if="{{currentUserRole === 'admin' && exportedQrFileIds.length}}" class="export-card">
    <view class="export-card-head">
      <text class="export-card-title">导出清单</text>
      <text class="export-card-count">{{exportedQrFileIds.length}} 条</text>
    </view>
    <view class="export-card-list">
      <view class="export-card-item" wx:for="{{exportedRecords}}" wx:key="_id">
        <text class="export-card-code">{{item.code_value || '无内容'}}</text>
        <text class="export-card-meta">{{item.category_name || '未分类'}} · {{item.status || 'pending'}}</text>
        <text class="export-card-file">{{item.qr_file_id}}</text>
      </view>
    </view>
  </view>

  <text wx:if="{{isBatchMode}}" class="batch-mode-tip">勾选记录后，可在底部进行批量操作。</text>

  <view wx:if="{{isLoadingRecords && !categoryGroups.length}}" class="records-loading-card">
    <text class="records-empty-text">记录加载中...</text>
  </view>

  <text wx:elif="{{isLoadingRecords}}" class="records-refresh-tip">记录加载中...</text>

  <block wx:if="{{categoryGroups.length}}">
    <view class="cat-section" wx:for="{{categoryGroups}}" wx:key="id">
      <view
        class="cat-section-head cat-section-head-clickable"
        hover-class="cat-section-head-hover"
        data-category-id="{{item.items[0].categoryId}}"
        data-category-name="{{item.categoryName}}"
        bindtap="handleEnterCategoryView"
      >
        <view class="cat-section-head-main">
          <text class="cat-section-title">{{item.categoryName}}</text>
          <text class="cat-section-subtitle">点击查看该分类</text>
        </view>
        <view wx:if="{{!isBatchMode}}" class="cat-section-view-side">
          <text class="cat-section-count">{{item.count}} 条</text>
          <text
            class="cat-section-enter-btn"
            data-category-id="{{item.items[0].categoryId}}"
            data-category-name="{{item.categoryName}}"
            catchtap="handleEnterCategoryView"
          >
            进入
          </text>
          <text
            wx:if="{{!canViewAllRecords}}"
            class="cat-section-more-btn"
            data-category-id="{{item.items[0].categoryId}}"
            data-category-name="{{item.categoryName}}"
            catchtap="handleOpenCategoryActions"
          >
            ⋯
          </text>
        </view>
        <view wx:else class="cat-section-head-action">
          <text class="cat-section-selected">{{item.selectedCount}} 已选</text>
          <text class="cat-section-toggle" data-id="{{item.id}}" bindtap="handleToggleCategorySelect">
            {{item.allSelected ? '取消本组' : '全选当前分类'}}
          </text>
        </view>
      </view>

      <view class="record-cell-grid">
        <view
          class="record-cell"
          wx:for="{{item.items}}"
          wx:for-item="record"
          wx:key="id"
          data-id="{{record.id}}"
          data-category-id="{{record.categoryId}}"
          bindtap="handleOpenViewer"
        >
          <view class="record-cell-top">
            <view class="record-cell-main">
              <view
                wx:if="{{isBatchMode && record.canOperate}}"
                class="record-check {{record.isSelected ? 'record-check-active' : ''}}"
                data-id="{{record.id}}"
                catchtap="handleToggleRecordSelect"
              >
                <text class="record-check-icon">{{record.isSelected ? '✓' : ''}}</text>
              </view>
              <view class="record-cell-content">
                <image wx:if="{{record.qrFileId}}" class="record-cell-qr" src="{{record.qrFileId}}" mode="aspectFit" />
                <view wx:else class="record-cell-qr-placeholder">
                  <text class="record-cell-qr-placeholder-text">无图</text>
                </view>
                <text wx:if="{{record.showCodeValue}}" class="record-cell-code">{{record.codeValue}}</text>
              </view>
            </view>
            <text class="record-status-tag {{record.statusClassName}}">{{record.statusText}}</text>
          </view>
          <view class="record-cell-body">
            <view class="record-cell-meta">
              <text class="record-cell-type">{{record.codeTypeText}}</text>
              <text wx:if="{{canViewAllRecords}}" class="record-cell-user">{{record.userDisplayName}}</text>
              <text class="record-cell-time">{{record.scanTime}}</text>
            </view>

            <view wx:if="{{!isBatchMode && record.canOperate && record.status === 'pending'}}" class="record-action-row">
              <button
                class="record-action-btn action-primary"
                data-id="{{record.id}}"
                data-code="{{record.codeValue}}"
                disabled="{{processingRecordId === record.id}}"
                catchtap="handleMarkRecord"
              >
                {{processingRecordId === record.id ? '处理中' : '标记'}}
              </button>
            </view>

            <view wx:elif="{{!isBatchMode && record.canOperate && record.status === 'marked'}}" class="record-action-row">
              <button
                class="record-action-btn action-secondary"
                data-id="{{record.id}}"
                data-code="{{record.codeValue}}"
                disabled="{{processingRecordId === record.id}}"
                catchtap="handleUndoMarkRecord"
              >
                {{processingRecordId === record.id ? '处理中' : '撤回'}}
              </button>
              <button
                class="record-action-btn action-primary"
                data-id="{{record.id}}"
                data-code="{{record.codeValue}}"
                disabled="{{processingRecordId === record.id}}"
                catchtap="handleArchiveRecord"
              >
                {{processingRecordId === record.id ? '处理中' : '归档'}}
              </button>
            </view>

            <view wx:elif="{{!isBatchMode && record.canOperate}}" class="record-action-row record-action-row-static">
              <text class="record-archived-text">已归档</text>
            </view>

            <view wx:elif="{{!isBatchMode}}" class="record-action-row record-action-row-static">
              <text class="record-archived-text">仅可查看</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <view wx:else class="records-loading-card">
    <text wx:if="{{allRecords.length}}" class="records-empty-text">暂无匹配记录</text>
    <text wx:else class="records-empty-text">暂无云端记录，先回首页扫一个码吧。</text>
  </view>

  <view wx:if="{{isBatchMode}}" class="batch-footer-space"></view>

  <view wx:if="{{categoryRenameDialogVisible}}" class="dialog-mask" bindtap="handleCloseCategoryRenameDialog">
    <view class="dialog-card" catchtap="noop">
      <text class="dialog-title">修改分类名称</text>
      <text class="dialog-subtitle">请输入新的分类名称</text>
      <input
        class="dialog-input"
        value="{{categoryRenameValue}}"
        placeholder="请输入分类名称"
        focus="{{categoryRenameDialogVisible}}"
        bindinput="handleCategoryRenameInput"
      />
      <view class="dialog-actions">
        <button
          class="dialog-btn dialog-btn-secondary"
          disabled="{{isCategoryActionProcessing}}"
          bindtap="handleCloseCategoryRenameDialog"
        >
          取消
        </button>
        <button
          class="dialog-btn dialog-btn-primary"
          disabled="{{isCategoryActionProcessing}}"
          bindtap="handleConfirmCategoryRename"
        >
          {{isCategoryActionProcessing ? '处理中' : '确认'}}
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{filterSheetVisible}}" class="dialog-mask" bindtap="handleCloseFilterSheet">
    <view class="filter-sheet-card" catchtap="noop">
      <view class="filter-sheet-head">
        <text class="filter-sheet-title">{{filterSheetTitle}}</text>
        <text class="filter-sheet-close" bindtap="handleCloseFilterSheet">关闭</text>
      </view>
      <scroll-view class="filter-sheet-body" scroll-y="true">
        <view
          wx:for="{{filterSheetOptions}}"
          wx:key="value"
          class="filter-sheet-option {{filterSheetSelectedValue === item.value ? 'filter-sheet-option-active' : ''}}"
          data-mode="{{filterSheetMode}}"
          data-value="{{item.value}}"
          bindtap="handleSelectFilterOption"
        >
          <text class="filter-sheet-option-label">{{item.label}}</text>
          <text wx:if="{{filterSheetSelectedValue === item.value}}" class="filter-sheet-option-check">已选</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{isBatchMode}}" class="batch-footer">
    <view class="batch-footer-summary">
      <text class="batch-footer-count">已选择 {{selectedCount}} 条</text>
      <text class="batch-footer-desc">底部仅显示当前可执行操作</text>
    </view>

    <view class="batch-footer-actions">
      <button
        wx:if="{{selectedPendingCount > 0}}"
        class="batch-footer-btn batch-footer-btn-primary"
        disabled="{{isBatchProcessing}}"
        data-action="mark"
        bindtap="handleBatchAction"
      >
        {{isBatchProcessing && batchProcessingAction === 'mark' ? '处理中' : '标记'}}
      </button>

      <button
        wx:if="{{selectedMarkedCount > 0}}"
        class="batch-footer-btn batch-footer-btn-secondary"
        disabled="{{isBatchProcessing}}"
        data-action="undo"
        bindtap="handleBatchAction"
      >
        {{isBatchProcessing && batchProcessingAction === 'undo' ? '处理中' : '撤回'}}
      </button>

      <button
        wx:if="{{selectedMarkedCount > 0}}"
        class="batch-footer-btn batch-footer-btn-primary"
        disabled="{{isBatchProcessing}}"
        data-action="archive"
        bindtap="handleBatchAction"
      >
        {{isBatchProcessing && batchProcessingAction === 'archive' ? '处理中' : '归档'}}
      </button>

      <text wx:if="{{selectedCount === 0}}" class="batch-footer-empty">请选择记录</text>
      <text
        wx:elif="{{selectedPendingCount === 0 && selectedMarkedCount === 0}}"
        class="batch-footer-empty"
      >
        所选记录当前不可批量操作
      </text>
    </view>
  </view>
</view>
