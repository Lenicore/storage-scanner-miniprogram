.records-page {
  min-height: 100vh;
  padding: 48rpx 24rpx 40rpx;
  background: #f2f2f7;
}

.records-hero {
  margin-bottom: 20rpx;
  padding: 8rpx 8rpx 12rpx;
}

.records-title {
  display: block;
  color: #111111;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
}

.records-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.6;
}

.admin-banner {
  margin-bottom: 18rpx;
  padding: 18rpx 20rpx;
  background: #111111;
  border-radius: 18rpx;
}

.admin-banner-text {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.5;
}

.current-category-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
  padding: 20rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
}

.current-category-main {
  flex: 1;
  min-width: 0;
}

.current-category-label {
  display: block;
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 1.4;
}

.current-category-name {
  display: block;
  margin-top: 8rpx;
  color: #111111;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
  word-break: break-all;
}

.current-category-back {
  flex-shrink: 0;
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.search-card {
  margin-bottom: 18rpx;
  padding: 20rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
}

.filter-date-box,
.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 18rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
}

.filter-date-input,
.search-input {
  flex: 1;
  height: 76rpx;
  color: #111111;
  font-size: 26rpx;
}

.filter-date-clear,
.search-clear {
  flex-shrink: 0;
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.search-box-secondary {
  margin-top: 14rpx;
}

.filter-select-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.filter-select-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  min-width: 0;
  flex: 1;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  box-sizing: border-box;
}

.filter-select-card-wide {
  flex: 1.2;
}

.filter-select-label {
  flex-shrink: 0;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.4;
}

.filter-select-value-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  min-width: 0;
  flex: 1;
}

.filter-select-value {
  min-width: 0;
  color: #111111;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.filter-select-arrow {
  flex-shrink: 0;
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 1;
}

.filter-tip {
  display: block;
  margin-top: 10rpx;
  color: #d97706;
  font-size: 22rpx;
  line-height: 1.5;
}

.batch-toolbar {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.batch-toggle-btn,
.batch-clear-btn {
  height: 76rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 76rpx;
  box-sizing: border-box;
}

.batch-toggle-btn {
  flex: 1;
  border: 0;
  background: #111111;
  color: #ffffff;
}

.batch-toggle-btn-active {
  background: #374151;
}

.batch-clear-btn {
  flex-shrink: 0;
  border: 1rpx solid #d1d5db;
  background: #ffffff;
  color: #374151;
}

.batch-clear-btn[disabled] {
  background: #f3f4f6;
  color: #9ca3af;
  border-color: #e5e7eb;
}

.batch-mode-tip {
  display: block;
  margin-bottom: 18rpx;
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.6;
}

.export-card {
  margin-bottom: 18rpx;
  padding: 20rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
}

.export-card-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.export-card-title {
  color: #111111;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.export-card-count {
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 1.4;
}

.export-card-list {
  margin-top: 16rpx;
}

.export-card-item + .export-card-item {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #f0f0f0;
}

.export-card-code {
  display: block;
  color: #111111;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
  word-break: break-all;
}

.export-card-meta {
  display: block;
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.4;
}

.export-card-file {
  display: block;
  margin-top: 6rpx;
  color: #8e8e93;
  font-size: 20rpx;
  line-height: 1.5;
  word-break: break-all;
}

.records-loading-card {
  padding: 40rpx 28rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
}

.records-empty-text {
  color: #8e8e93;
  font-size: 26rpx;
  line-height: 1.6;
}

.records-refresh-tip {
  display: block;
  margin-bottom: 18rpx;
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.5;
}

.cat-section {
  margin-bottom: 24rpx;
  padding: 24rpx 20rpx 20rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
}

.cat-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx;
  border-bottom: 1rpx solid #e8e8ed;
  border-radius: 18rpx;
  background: #f8fafc;
}

.cat-section-head-main {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  gap: 8rpx;
}

.cat-section-head-clickable {
  cursor: pointer;
}

.cat-section-head-hover {
  background: #f1f5f9;
}

.cat-section-head-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.cat-section-view-side {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  gap: 12rpx;
}

.cat-section-title {
  color: #111111;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
}

.cat-section-subtitle {
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 1.4;
}

.cat-section-count {
  flex-shrink: 0;
  color: #8e8e93;
  font-size: 24rpx;
  font-weight: 500;
}

.cat-section-selected {
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 1.4;
}

.cat-section-toggle {
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.cat-section-enter-btn {
  min-width: 88rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #1677ff;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
  text-align: center;
}

.cat-section-more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #374151;
  font-size: 34rpx;
  line-height: 1;
  border: 1rpx solid #e5e7eb;
  box-sizing: border-box;
}

.record-cell-grid {
  display: flex;
  flex-wrap: wrap;
  align-items: stretch;
  gap: 12rpx;
  padding-top: 18rpx;
}

.record-cell {
  width: calc((100% - 12rpx) / 2);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  height: 372rpx;
  padding: 18rpx 16rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  overflow: hidden;
}

.record-cell-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.record-cell-main {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.record-cell-content {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  min-height: 152rpx;
}

.record-cell-body {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-height: 0;
}

.record-cell-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-height: 80rpx;
  margin-top: 10rpx;
}

.record-check {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  margin-top: 2rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 10rpx;
  background: #ffffff;
  box-sizing: border-box;
  flex-shrink: 0;
}

.record-check-active {
  border-color: #1677ff;
  background: #1677ff;
}

.record-check-icon {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.record-cell-code {
  display: block;
  min-width: 0;
  margin-top: 12rpx;
  color: #111111;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.45;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-cell-qr,
.record-cell-qr-placeholder {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 12rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
}

.record-cell-qr-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-cell-qr-placeholder-text {
  color: #9ca3af;
  font-size: 20rpx;
}

.record-status-tag {
  flex-shrink: 0;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
}

.status-pending {
  background: #eff6ff;
  color: #2563eb;
}

.status-marked {
  background: #fff7ed;
  color: #c2410c;
}

.status-archived {
  background: #f3f4f6;
  color: #6b7280;
}

.record-cell-type {
  display: block;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-cell-time {
  display: block;
  color: #9ca3af;
  font-size: 20rpx;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-cell-user {
  display: block;
  color: #6b7280;
  font-size: 20rpx;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-action-row {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-end;
  gap: 10rpx;
  min-height: 56rpx;
  margin-top: auto;
  padding-top: 14rpx;
}

.record-action-row-static {
  align-items: center;
}

.record-action-btn {
  min-width: 104rpx;
  height: 56rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 56rpx;
  box-sizing: border-box;
}

.action-primary {
  border: 0;
  background: #1677ff;
  color: #ffffff;
}

.action-secondary {
  border: 1rpx solid #d1d5db;
  background: #ffffff;
  color: #374151;
}

.record-action-btn[disabled] {
  background: #e5e7eb;
  color: #9ca3af;
  border-color: #e5e7eb;
}

.record-archived-text {
  color: #9ca3af;
  font-size: 22rpx;
  line-height: 1.4;
}

.batch-footer-space {
  height: 220rpx;
}

.dialog-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: rgba(0, 0, 0, 0.35);
  box-sizing: border-box;
}

.dialog-card {
  width: 100%;
  padding: 28rpx 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.12);
  box-sizing: border-box;
}

.dialog-title {
  display: block;
  color: #111111;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
}

.dialog-subtitle {
  display: block;
  margin-top: 10rpx;
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.5;
}

.dialog-input {
  width: 100%;
  height: 84rpx;
  margin-top: 20rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  box-sizing: border-box;
  color: #111111;
  font-size: 28rpx;
}

.dialog-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 22rpx;
}

.dialog-btn {
  min-width: 120rpx;
  height: 72rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 72rpx;
  box-sizing: border-box;
}

.dialog-btn-primary {
  border: 0;
  background: #1677ff;
  color: #ffffff;
}

.dialog-btn-secondary {
  border: 1rpx solid #d1d5db;
  background: #ffffff;
  color: #374151;
}

.dialog-btn[disabled] {
  background: #e5e7eb;
  color: #9ca3af;
  border-color: #e5e7eb;
}

.filter-sheet-card {
  align-self: flex-end;
  width: 100%;
  max-height: 70vh;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.12);
  overflow: hidden;
}

.filter-sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 28rpx 24rpx 18rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-sheet-title {
  color: #111111;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
}

.filter-sheet-close {
  flex-shrink: 0;
  color: #1677ff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.4;
}

.filter-sheet-body {
  max-height: 52vh;
}

.filter-sheet-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 26rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f7;
}

.filter-sheet-option-active {
  background: #f0f7ff;
}

.filter-sheet-option-label {
  flex: 1;
  min-width: 0;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.filter-sheet-option-check {
  flex-shrink: 0;
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.batch-footer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  z-index: 20;
  padding: 22rpx 20rpx calc(22rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid #e5e7eb;
  border-radius: 22rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.12);
  box-sizing: border-box;
}

.batch-footer-summary {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.batch-footer-count {
  color: #111111;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.batch-footer-desc {
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 1.4;
}

.batch-footer-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.batch-footer-btn {
  min-width: 112rpx;
  height: 60rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 60rpx;
  box-sizing: border-box;
}

.batch-footer-btn-primary {
  border: 0;
  background: #1677ff;
  color: #ffffff;
}

.batch-footer-btn-secondary {
  border: 1rpx solid #d1d5db;
  background: #ffffff;
  color: #374151;
}

.batch-footer-btn[disabled] {
  background: #e5e7eb;
  color: #9ca3af;
  border-color: #e5e7eb;
}

.batch-footer-empty {
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.6;
}
