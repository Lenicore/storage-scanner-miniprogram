.records-page {
  min-height: 100vh;
  padding: 48rpx 24rpx 40rpx;
  background: #f2f2f7;
}

.records-hero {
  margin-bottom: 20rpx;
  padding: 8rpx 8rpx 12rpx;
}

.records-title {
  display: block;
  color: #111111;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
}

.records-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.6;
}

.admin-banner {
  margin-bottom: 18rpx;
  padding: 18rpx 20rpx;
  background: #111111;
  border-radius: 18rpx;
}

.admin-banner-text {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.5;
}

.search-card {
  margin-bottom: 18rpx;
  padding: 20rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
}

.search-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 18rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
}

.search-input {
  flex: 1;
  height: 76rpx;
  color: #111111;
  font-size: 26rpx;
}

.search-clear {
  flex-shrink: 0;
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.search-box-secondary {
  margin-top: 14rpx;
}

.filter-block + .filter-block {
  margin-top: 16rpx;
}

.filter-label {
  display: block;
  margin-bottom: 10rpx;
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 1.4;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-chip-row {
  display: inline-flex;
  gap: 10rpx;
  padding-right: 8rpx;
}

.filter-chip {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 1.4;
}

.filter-chip-active {
  background: #111111;
  color: #ffffff;
}

.batch-toolbar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.batch-toggle-btn,
.batch-clear-btn {
  height: 76rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 76rpx;
  box-sizing: border-box;
}

.batch-toggle-btn {
  flex: 1;
  border: 0;
  background: #111111;
  color: #ffffff;
}

.batch-toggle-btn-active {
  background: #374151;
}

.batch-clear-btn {
  flex-shrink: 0;
  border: 1rpx solid #d1d5db;
  background: #ffffff;
  color: #374151;
}

.batch-clear-btn[disabled] {
  background: #f3f4f6;
  color: #9ca3af;
  border-color: #e5e7eb;
}

.batch-mode-tip {
  display: block;
  margin-bottom: 18rpx;
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.6;
}

.records-loading-card {
  padding: 40rpx 28rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
}

.records-empty-text {
  color: #8e8e93;
  font-size: 26rpx;
  line-height: 1.6;
}

.records-refresh-tip {
  display: block;
  margin-bottom: 18rpx;
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.5;
}

.cat-section {
  margin-bottom: 24rpx;
  padding: 24rpx 20rpx 20rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
}

.cat-section-head {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 4rpx 4rpx 18rpx;
  border-bottom: 1rpx solid #e8e8ed;
}

.cat-section-head-main {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.cat-section-head-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.cat-section-title {
  flex: 1;
  min-width: 0;
  color: #111111;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
}

.cat-section-count {
  flex-shrink: 0;
  color: #8e8e93;
  font-size: 24rpx;
  font-weight: 500;
}

.cat-section-selected {
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 1.4;
}

.cat-section-toggle {
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.record-cell-grid {
  display: flex;
  flex-wrap: wrap;
  align-items: stretch;
  gap: 12rpx;
  padding-top: 18rpx;
}

.record-cell {
  width: calc((100% - 12rpx) / 2);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  height: 372rpx;
  padding: 18rpx 16rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  overflow: hidden;
}

.record-cell-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.record-cell-main {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.record-cell-content {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  min-height: 152rpx;
}

.record-cell-body {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-height: 0;
}

.record-cell-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-height: 80rpx;
  margin-top: 10rpx;
}

.record-check {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  margin-top: 2rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 10rpx;
  background: #ffffff;
  box-sizing: border-box;
  flex-shrink: 0;
}

.record-check-active {
  border-color: #1677ff;
  background: #1677ff;
}

.record-check-icon {
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.record-cell-code {
  display: block;
  min-width: 0;
  margin-top: 12rpx;
  color: #111111;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.45;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-cell-qr,
.record-cell-qr-placeholder {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 12rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
}

.record-cell-qr-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-cell-qr-placeholder-text {
  color: #9ca3af;
  font-size: 20rpx;
}

.record-status-tag {
  flex-shrink: 0;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
}

.status-pending {
  background: #eff6ff;
  color: #2563eb;
}

.status-marked {
  background: #fff7ed;
  color: #c2410c;
}

.status-archived {
  background: #f3f4f6;
  color: #6b7280;
}

.record-cell-type {
  display: block;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-cell-time {
  display: block;
  color: #9ca3af;
  font-size: 20rpx;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-cell-user {
  display: block;
  color: #6b7280;
  font-size: 20rpx;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.record-action-row {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-end;
  gap: 10rpx;
  min-height: 56rpx;
  margin-top: auto;
  padding-top: 14rpx;
}

.record-action-row-static {
  align-items: center;
}

.record-action-btn {
  min-width: 104rpx;
  height: 56rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 56rpx;
  box-sizing: border-box;
}

.action-primary {
  border: 0;
  background: #1677ff;
  color: #ffffff;
}

.action-secondary {
  border: 1rpx solid #d1d5db;
  background: #ffffff;
  color: #374151;
}

.record-action-btn[disabled] {
  background: #e5e7eb;
  color: #9ca3af;
  border-color: #e5e7eb;
}

.record-archived-text {
  color: #9ca3af;
  font-size: 22rpx;
  line-height: 1.4;
}

.batch-footer-space {
  height: 220rpx;
}

.batch-footer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  z-index: 20;
  padding: 22rpx 20rpx calc(22rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid #e5e7eb;
  border-radius: 22rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.12);
  box-sizing: border-box;
}

.batch-footer-summary {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.batch-footer-count {
  color: #111111;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.batch-footer-desc {
  color: #8e8e93;
  font-size: 22rpx;
  line-height: 1.4;
}

.batch-footer-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.batch-footer-btn {
  min-width: 112rpx;
  height: 60rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 60rpx;
  box-sizing: border-box;
}

.batch-footer-btn-primary {
  border: 0;
  background: #1677ff;
  color: #ffffff;
}

.batch-footer-btn-secondary {
  border: 1rpx solid #d1d5db;
  background: #ffffff;
  color: #374151;
}

.batch-footer-btn[disabled] {
  background: #e5e7eb;
  color: #9ca3af;
  border-color: #e5e7eb;
}

.batch-footer-empty {
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.6;
}
