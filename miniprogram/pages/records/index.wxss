.records-page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background: #f5f5f7;
}

.records-hero {
  margin-bottom: 24rpx;
  padding: 8rpx 8rpx 16rpx;
}

.records-title {
  display: block;
  color: #111111;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
}

.records-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.6;
}

.records-card {
  padding: 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

.batch-group + .batch-group {
  margin-top: 32rpx;
}

.batch-title {
  display: block;
  margin-bottom: 12rpx;
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.5;
}

.record-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eeeeee;
}

.record-item:last-child {
  border-bottom: 0;
}

.record-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.record-type {
  color: #666666;
  font-size: 24rpx;
  line-height: 1.5;
}

.record-time {
  flex-shrink: 0;
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.5;
}

.record-value {
  display: block;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.record-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.record-category {
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.5;
}

.record-dot {
  color: #c4c4c4;
  font-size: 22rpx;
  line-height: 1.5;
}

.record-status {
  display: block;
  color: #8e8e93;
  font-size: 24rpx;
  line-height: 1.5;
}

.records-empty {
  padding: 8rpx 0;
}

.records-empty-text {
  color: #8e8e93;
  font-size: 26rpx;
  line-height: 1.6;
}
